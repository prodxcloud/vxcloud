{
  "name": "@vxcloud/sdk",
  "version": "2026.6.15",
  "description": "TypeScript SDK for the vxcloud / VxCloud platform — provision infrastructure, deploy applications, and manage running services from your terminal or CI pipeline.",
  "license": "Apache-2.0",
  "author": "vxcloud <engineering@vxcloud.io>",
  "homepage": "https://vxcloud.io/docs/sdks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prodxcloud/vxcloud.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/prodxcloud/vxcloud/issues"
  },
  "keywords": [
    "vxcloud",
    "vxcloud",
    "vxcli",
    "infrastructure",
    "iac",
    "deploy",
    "ssh",
    "docker",
    "kubernetes",
    "ai-agents",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
